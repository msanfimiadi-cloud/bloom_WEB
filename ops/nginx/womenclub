server {
    listen 80;
    server_name bloomclub.ru www.bloomclub.ru;

    return 301 https://$host$request_uri;
}

server {
    listen 80;
    server_name app.bloomclub.ru;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name bloomclub.ru www.bloomclub.ru;

    root /opt/fed_women_club_WEB/frontend/dist;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/bloomclub.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bloomclub.ru/privkey.pem;

    # Public WEB must never expose the Browser Mobile App login-code flow.
    location = /api/v1/auth/login-code {
        return 404;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        proxy_pass http://127.0.0.1:8000/uploads/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 443 ssl http2;
    server_name app.bloomclub.ru;

    root /opt/fed_women_club_WEB/browser-mobile-app/dist;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/bloomclub.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bloomclub.ru/privkey.pem;

    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        proxy_pass http://127.0.0.1:8000/uploads/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
