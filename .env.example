ENV=local
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/federal_women_club
CONTENT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bloom_club_content
SECRET_KEY=change-me
SITE_CREDENTIALS_SECRET=change-me-site-credentials
BOT_SERVICE_TOKEN=change-me
BOT_API_TOKEN=change-me-for-vk-bot-service-token
TELEGRAM_ADMIN_API_TOKEN=change-me-telegram-admin-api-token

# Legacy WEB content admin writes are enabled by default.
# Set to false to make legacy WEB content write endpoints read-only;
# Content Admin API /api/content/admin/* continues to work with TELEGRAM_ADMIN_API_TOKEN.
WEB_ADMIN_LEGACY_CONTENT_WRITE_ENABLED=true

# Tochka internet acquiring. JWT permissions: MakeAcquiringOperation,
# ReadAcquiringData, ReadCustomerData, ManageWebhookData.
TOCHKA_PAYMENTS_ENABLED=false
TOCHKA_API_BASE_URL=https://enter.tochka.com/uapi
TOCHKA_JWT_TOKEN=
TOCHKA_CLIENT_ID=
TOCHKA_CUSTOMER_CODE=
TOCHKA_MERCHANT_ID=
TOCHKA_TERMINAL_ID=
TOCHKA_PAYMENT_MODES=sbp,card
TOCHKA_PAYMENT_LINK_TTL_MINUTES=60
TOCHKA_WEBHOOK_PUBLIC_KEY=
TOCHKA_WEBHOOK_URL=https://bloomclub.ru/api/v1/payments/tochka/webhook
TOCHKA_SUCCESS_REDIRECT_URL=https://app.bloomclub.ru/payment/success
TOCHKA_FAIL_REDIRECT_URL=https://app.bloomclub.ru/payment/fail
TOCHKA_REQUEST_TIMEOUT_SECONDS=15
TOCHKA_RECONCILIATION_ENABLED=true
TOCHKA_RECONCILIATION_INTERVAL_MINUTES=5
TOCHKA_TAX_SYSTEM_CODE=
TOCHKA_VAT_TYPE=none
TOCHKA_PAYMENT_METHOD=full_payment
TOCHKA_PAYMENT_OBJECT=service
LEAD_HASH_SALT=change-me
BACKEND_CORS_ORIGINS=https://bloomclub.ru,https://www.bloomclub.ru,https://kosmos327-fed-women-club-mini-app-3f15.twc1.net
WEB_PUBLIC_URL=https://women-club.example
VITE_API_BASE_URL=http://127.0.0.1:8000
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
